# ── Copy this file to ".env.local" and fill in real values. ──
# .env.local is gitignored. Restart `npm run dev` after changing it.

# Admin panel login (the /admin page). Pick a strong password.
ADMIN_PASSWORD=change-this-password

# ── Email (Gmail / SMTP via Nodemailer) ──
# For Gmail: turn on 2-Step Verification, then create an "App Password"
# (Google account > Security > App passwords) and use that as SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="The Heights Retreat <youraddress@gmail.com>"
# Where inquiry notifications are delivered (defaults to SMTP_USER if blank):
ADMIN_EMAIL=youraddress@gmail.com

# ── Firebase Admin (server-side Firestore writes) ──
# Firebase console > Project settings > Service accounts > Generate new private key.
# From that JSON: project_id, client_email, private_key.
# Keep the private key on ONE line with literal \n for newlines, wrapped in quotes.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...your key...\n-----END PRIVATE KEY-----\n"
